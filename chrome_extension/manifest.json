{
  "manifest_version": 3,
  "name": "Aนษื๖Tผเฟุึ๚สึ",
  "version": "1.0",
  "description": "สตสฑAนษื๖Tย๒ย๔ตใผเฟุฃฌึงณึฤฃฤโฒโสิ",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.eastmoney.com/*",
    "*://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
